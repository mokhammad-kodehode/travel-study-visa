RESEND_API_KEY=your_resend_api_key_here
CONTACT_RECEIVER_EMAIL=your@email.com
CONTACT_SENDER_EMAIL=onboarding@resend.dev
NEXT_PUBLIC_SITE_URL=https://www.travelandstudy.ru

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
# Server-side read token for fetching content from Sanity (required at runtime)
SANITY_API_READ_TOKEN=
# Only needed for migration scripts (write access). Not required for site to run.
SANITY_API_WRITE_TOKEN=
